# VisuaLearn Frontend Environment Variables
# Copy this file to .env and fill in your values

# ===========================================
# REQUIRED - App will not work without these
# ===========================================

# Supabase Configuration (use the ANON key, not service key!)
# Get these from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# ===========================================
# OPTIONAL
# ===========================================

# Backend API URL (defaults to localhost:3001 in development)
# VITE_API_URL=http://localhost:3001

# Unsplash API Configuration (for image search in learning content)
# Get your API key at: https://unsplash.com/developers
# If not set, falls back to placeholder images
# VITE_UNSPLASH_ACCESS_KEY=your_unsplash_access_key_here
