# VisuaLearn Backend Environment Variables
# Copy this file to .env and fill in your values

# ===========================================
# REQUIRED - Server will not start without these
# ===========================================

# Supabase Configuration
# Get these from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_KEY=your-supabase-service-role-key

# Azure OpenAI chat model
AZURE_OPENAI_API_KEY=your-azure-openai-key
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_DEPLOYMENT=your-chat-deployment-name
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# Azure OpenAI embeddings for document RAG
# AZURE_EMBEDDING_ENDPOINT may be either the resource endpoint
# or the full embeddings URL from Azure Foundry.
AZURE_EMBEDDING_ENDPOINT=https://your-resource.cognitiveservices.azure.com/openai/deployments/text-embedding-ada-002/embeddings?api-version=2023-05-15
AZURE_EMBEDDING_API_KEY=your-azure-embedding-key
AZURE_EMBEDDING_DEPLOYMENT=text-embedding-ada-002
AZURE_EMBEDDING_MODEL=text-embedding-ada-002
AZURE_EMBEDDING_API_VERSION=2023-05-15

# Notion export integration
NOTION_CLIENT_ID=your-notion-oauth-client-id
NOTION_CLIENT_SECRET=your-notion-oauth-client-secret
# Local:
NOTION_REDIRECT_URI=http://localhost:3001/api/notion/callback
# Production:
# NOTION_REDIRECT_URI=https://visualearnai-backend.onrender.com/api/notion/callback
NOTION_VERSION=2026-03-11
NOTION_TOKEN_ENCRYPTION_KEY=your-32-byte-or-longer-random-secret
FRONTEND_URL=http://localhost:5173
# Production:
# FRONTEND_URL=https://visualearn-ai.vercel.app
# BACKEND_PUBLIC_URL=https://visualearnai-backend.onrender.com

# ===========================================
# OPTIONAL - For additional features
# ===========================================

# Azure OpenAI (for text-to-speech and image generation)
# Get from: https://portal.azure.com

# Azure Image Generation
# AZURE_IMAGE_ENDPOINT=https://your-resource.openai.azure.com
# AZURE_IMAGE_API_VERSION=2024-02-01

# Azure Text-to-Speech
# AZURE_TTS_MODEL=your-tts-deployment-name
# AZURE_TTS_API_VERSION=your-tts-api-version

# Server Configuration
PORT=3001
NODE_ENV=development
LOG_LEVEL=info

# Rate Limiting
# RATE_LIMIT_CHAT_MAX=30
# RATE_LIMIT_CHAT_WINDOW_SECS=60
# RATE_LIMIT_GENERAL_MAX=100
# RATE_LIMIT_GENERAL_WINDOW_SECS=60

# CORS (comma-separated origins)
# CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:4173,https://visualearn-ai.vercel.app
# CORS_ALLOW_VERCEL_PREVIEWS=true

# Redis (optional - for distributed rate limiting in production)
# REDIS_URL=redis://localhost:6379
