# VisuaLearn Backend Environment Variables
# Copy this file to .env and fill in your values

# ===========================================
# REQUIRED - Server will not start without these
# ===========================================

# Supabase Configuration
# Get these from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_KEY=your-supabase-service-role-key

# Anthropic Claude API
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your-anthropic-api-key
ANTHROPIC_MODEL=claude-sonnet-4-5

# ===========================================
# OPTIONAL - For additional features
# ===========================================

# Anthropic Base URL (only if using a proxy or custom endpoint)
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# Azure OpenAI (for text-to-speech and image generation)
# Get from: https://portal.azure.com
# AZURE_OPENAI_API_KEY=your-azure-openai-key
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com

# Azure Image Generation
# AZURE_IMAGE_ENDPOINT=https://your-resource.openai.azure.com
# AZURE_IMAGE_API_VERSION=2024-02-01

# Azure Text-to-Speech
# AZURE_TTS_MODEL=tts-1

# Azure Realtime Voice (gpt-realtime-1.5 or gpt-4o-mini-realtime-preview)
# Provide the FULL URL with deployment name included
# AZURE_REALTIME_ENDPOINT=https://your-resource.cognitiveservices.azure.com/openai/realtime?api-version=2024-10-01-preview&deployment=gpt-realtime-1.5
# AZURE_REALTIME_API_KEY=your-realtime-api-key

# Server Configuration
PORT=3001
NODE_ENV=development
LOG_LEVEL=info

# Rate Limiting
# RATE_LIMIT_CHAT_MAX=30
# RATE_LIMIT_CHAT_WINDOW_SECS=60
# RATE_LIMIT_GENERAL_MAX=100
# RATE_LIMIT_GENERAL_WINDOW_SECS=60

# CORS (comma-separated origins, defaults to http://localhost:5173)
# CORS_ORIGIN=http://localhost:5173,https://your-production-domain.com

# Redis (optional - for distributed rate limiting in production)
# REDIS_URL=redis://localhost:6379
